{
  "manifest_version": 3,
  "version": "1.0",
  "name": "Tokyo Night Night",
  "description": "Tokyo Night Night colorscheme for Chromium/Chrome",
  "theme": {
    "images": {
      "theme_frame":                "images/theme_frame.png",
      "theme_frame_inactive":       "images/theme_frame.png",
      "theme_toolbar":              "images/theme_toolbar.png",
      "theme_tab_background":       "images/theme_tab_background.png",
      "theme_ntp_background":       "images/theme_ntp_background.png"
    },

    "colors": {
      "frame":                        [22, 22, 30],
      "frame_inactive":               [22, 22, 30],
      "frame_incognito":              [16, 16, 24],
      "frame_incognito_inactive":     [16, 16, 24],

      "toolbar":                      [26, 27, 38],
      "toolbar_button_icon":          [169, 177, 214],
      "toolbar_button_icon_inactive": [86, 95, 137],

      "tab_background_text":          [86, 95, 137],
      "tab_background_text_inactive": [65, 72, 104],
      "tab_text":                     [192, 202, 245],

      "bookmark_text":                [169, 177, 214],

      "ntp_background":               [26, 27, 38],
      "ntp_text":                     [192, 202, 245],
      "ntp_link":                     [122, 162, 247],
      "ntp_header":                   [22, 22, 30],

      "omnibox_background":           [22, 22, 30],
      "omnibox_text":                 [192, 202, 245],

      "button_background":            [41, 46, 66],
      "control_background":           [31, 35, 53]
    },

    "tints": {
      "buttons":            [0.61, 0.60, 0.85],
      "frame":              [-1, -1, -1],
      "frame_inactive":     [-1, -1, -1],
      "background_tab":     [-1, -1, 0.13]
    },

    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat":    "no-repeat",
      "ntp_logo_alternate":       1
    }
  }
}
